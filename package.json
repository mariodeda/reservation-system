{
  "name": "reservation-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node --max-old-space-size=2048 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "platform": "node scripts/platform.mjs",
    "tenant": "node scripts/tenant.mjs"
  },
  "dependencies": {
    "mysql2": "^3.22.5",
    "next": "16.2.9",
    "nodemailer": "^9.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "mysql-memory-server": "^1.14.1",
    "playwright-core": "^1.61.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "adm-zip": "0.6.0",
    "brace-expansion": "5.0.7",
    "esbuild": "0.28.1",
    "postcss": "$postcss"
  }
